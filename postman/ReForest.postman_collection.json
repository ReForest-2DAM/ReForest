    {
      "name": "Especies",
      "item": [
        {
          "name": "POST OK - Crear especie Encina",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has expected structure\", function () {\r",
                  "    const json = pm.response.json();\r",
                  "\r",
                  "    pm.expect(json).to.have.property(\"id\");\r",
                  "    pm.expect(json).to.have.property(\"nombre_comun\");\r",
                  "    pm.expect(json).to.have.property(\"descripcion\");\r",
                  "    pm.expect(json).to.have.property(\"precio_plantacion\");\r",
                  "    pm.expect(json).to.have.property(\"zona_geografica\");\r",
                  "    pm.expect(json).to.have.property(\"co2_anual_kg\");\r",
                  "    pm.expect(json).to.have.property(\"altura_maxima_m\");\r",
                  "    pm.expect(json).to.have.property(\"disponible\");\r",
                  "    pm.expect(json).to.have.property(\"fecha_temporada\");\r",
                  "    pm.expect(json).to.have.property(\"image_url\");\r",
                  "\r",
                  "    pm.environment.set(\"especie_id\", json.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre_comun\": \"Encina mediterránea\",\n  \"descripcion\": \"Árbol autóctono muy resistente a la sequía, ideal para proyectos de reforestación en zonas mediterráneas.\",\n  \"precio_plantacion\": 24.75,\n  \"zona_geografica\": \"Mediterráneo\",\n  \"co2_anual_kg\": 28.5,\n  \"altura_maxima_m\": 25,\n  \"disponible\": true,\n  \"fecha_temporada\": \"2026-10-15\",\n  \"image_url\": \"https://res.cloudinary.com/demo/image/upload/v1700000000/reforest/encina.jpg\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
