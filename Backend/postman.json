              "name": "Éxito - Usuario Encontrado",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] } },
              "status": "OK", "code": 200, "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"id\": 1,\n    \"nombre\": \"Juan Pérez\",\n    \"email\": \"juan.perez@example.com\",\n    \"rol\": \"USER\"\n}"
            },
            {
              "name": "Error - Usuario No Encontrado",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/usuarios/99", "host": ["{{base_url}}"], "path": ["usuarios", "99"] } },
              "status": "Not Found", "code": 404, "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"code\": 404,\n    \"message\": \"Usuario no encontrado con ID: 99\"\n}"
            }
          ]
        },
        {
          "name": "POST - Crear nuevo usuario",
          "request": {
            "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Ana Torres\",\n  \"email\": \"ana.torres@example.com\",\n  \"contrasena\": \"securepass789\",\n  \"rol\": \"USER\"\n}" },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "POST - Crear usuario con email duplicado (Error 409)",
          "request": {
            "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Usuario Duplicado\",\n  \"email\": \"juan.perez@example.com\",\n  \"contrasena\": \"password123\",\n  \"rol\": \"USER\"\n}" },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          },
          "response": [
            {
              "name": "Error - Email ya existe",
              "originalRequest": { "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Usuario Duplicado\",\n  \"email\": \"juan.perez@example.com\",\n  \"contrasena\": \"password123\",\n  \"rol\": \"USER\"\n}" }, "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] } },
              "status": "Conflict", "code": 409, "_postman_previewlanguage": "json",
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\n    \"code\": 409,\n    \"message\": \"Conflicto de datos. Probablemente un campo único (como el email) ya existe.\"\n}"
            }
          ]
        },
        {
          "name": "PUT - Actualizar usuario completo",
          "request": {
            "method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Ana Torres García\",\n  \"email\": \"ana.torres.garcia@example.com\",\n  \"contrasena\": \"newsecurepass123\",\n  \"rol\": \"ADMIN\"\n}" },
            "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] }
          }
        },
        {
          "name": "PATCH - Actualizar usuario parcial",
          "request": {
            "method": "PATCH", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"rol\": \"USER\"\n}" },
            "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] }
          }
        },
        {
          "name": "DELETE - Eliminar usuario",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] } }
        }
      ]
    },
