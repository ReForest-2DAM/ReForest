      "name": "Especies",
      "item": [
        {
          "name": "GET - Listar todas las especies",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/especies", "host": ["{{base_url}}"], "path": ["especies"] } }
        },
        {
          "name": "GET - Obtener especie por ID",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/especies/99", "host": ["{{base_url}}"], "path": ["especies", "99"] } },
          "response": [
            {
              "name": "Éxito - Especie Encontrada",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/especies/1", "host": ["{{base_url}}"], "path": ["especies", "1"] } },
              "status": "OK", "code": 200, "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n    \"id\": 1,\n    \"nombre_comun\": \"Roble\",\n    \"descripcion\": \"Árbol de hoja caduca, robusto y longevo\",\n    \"precio_plantacion\": 15.5,\n    \"zona_geografica\": \"Europa templada\",\n    \"co2_anual_kg\": 21.8,\n    \"altura_maxima_m\": 40,\n    \"disponible\": true,\n    \"fecha_temporada\": \"2024-03-15\",\n    \"image_url\": \"https://example.com/roble.jpg\"\n}"
            },
            {
              "name": "Error - Especie No Encontrada",
              "originalRequest": { "method": "GET", "header": [], "url": { "raw": "{{base_url}}/especies/99", "host": ["{{base_url}}"], "path": ["especies", "99"] } },
              "status": "Not Found", "code": 404, "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n    \"code\": 404,\n    \"message\": \"Especie no encontrada con ID: 99\"\n}"
            }
          ]
        },
        {
          "name": "POST - Crear nueva especie",
          "request": {
            "method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"nombre_comun\": \"Pino Silvestre\",\n  \"descripcion\": \"Conífera de montaña, muy resistente.\",\n  \"precio_plantacion\": 12.00,\n  \"zona_geografica\": \"Zonas montañosas de Eurasia\",\n  \"co2_anual_kg\": 18.5,\n  \"altura_maxima_m\": 30,\n  \"disponible\": true,\n  \"fecha_temporada\": \"2024-02-01\",\n  \"image_url\": \"https://example.com/pino.jpg\"\n}" },
            "url": { "raw": "{{base_url}}/especies", "host": ["{{base_url}}"], "path": ["especies"] }
          }
        },
        {
          "name": "PUT - Actualizar especie completa",
          "request": {
            "method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"nombre_comun\": \"Pino Silvestre Actualizado\",\n  \"descripcion\": \"Conífera de montaña, muy resistente y de rápido crecimiento.\",\n  \"precio_plantacion\": 13.50,\n  \"zona_geografica\": \"Zonas montañosas de Eurasia y Pirineos\",\n  \"co2_anual_kg\": 19.0,\n  \"altura_maxima_m\": 35,\n  \"disponible\": false,\n  \"fecha_temporada\": \"2024-02-15\",\n  \"image_url\": \"https://example.com/pino-actualizado.jpg\"\n}" },
            "url": { "raw": "{{base_url}}/especies/1", "host": ["{{base_url}}"], "path": ["especies", "1"] }
          }
        },
        {
          "name": "PATCH - Actualizar especie parcial",
          "request": {
            "method": "PATCH", "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"precio_plantacion\": 14.00,\n  \"disponible\": false\n}" },
            "url": { "raw": "{{base_url}}/especies/1", "host": ["{{base_url}}"], "path": ["especies", "1"] }
          }
        },
        {
          "name": "DELETE - Eliminar especie",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "{{base_url}}/especies/1", "host": ["{{base_url}}"], "path": ["especies", "1"] } }
        }
      ]
    },
    {
